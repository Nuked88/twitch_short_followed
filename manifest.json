{
  "manifest_version": 3,
  "name": "Twitch Sort Followed",
  "version": "1.0",
  "description": "Custom drag-and-drop order for Twitch followed channels sidebar",
  "permissions": ["storage", "scripting", "activeTab"],
  "content_scripts": [
    {
      "matches": ["*://www.twitch.tv/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Twitch Sort Followed"
  }
}
